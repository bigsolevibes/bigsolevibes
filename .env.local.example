# ── Google Analytics ──────────────────────────────────────────────────────────
# Get your Measurement ID from: analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used for generating canonical URLs and social share links
NEXT_PUBLIC_SITE_URL=https://bigsolevibes.com

# ── Klaviyo ───────────────────────────────────────────────────────────────────
# Private API key — klaviyo.com → Settings → API Keys → Create Private API Key
# Scopes needed: Lists (read/write), Profiles (read/write), Subscriptions (write)
KLAVIYO_PRIVATE_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# List ID — klaviyo.com → Lists & Segments → your list → Settings tab → List ID
KLAVIYO_LIST_ID=XXXXXX

# ── Affiliate ─────────────────────────────────────────────────────────────────
# Your Amazon Associates tracking ID (e.g. bigsolevibes-20)
AMAZON_AFFILIATE_TAG=

# ── Google Analytics ──────────────────────────────────────────────────────────
# Get your Measurement ID from: analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used for generating canonical URLs and social share links
NEXT_PUBLIC_SITE_URL=https://bigsolevibes.com

# ── Email — Mailchimp ─────────────────────────────────────────────────────────
# Get from: mailchimp.com → Account → Extras → API Keys
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_API_SERVER=us1

# ── Email — Resend (alternative to Mailchimp) ─────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=

# ── Affiliate ─────────────────────────────────────────────────────────────────
# Your Amazon Associates tracking ID (e.g. bigsolevibes-20)
AMAZON_AFFILIATE_TAG=
